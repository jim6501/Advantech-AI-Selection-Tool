GOOGLE_SHEET_ID="你的_GOOGLE_SHEET_ID"
GOOGLE_CREDENTIALS_PATH="credentials.json"

# MongoDB Atlas 連線字串
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=advantech_ind_sw_tool

# ── Gemini API ───────────────────────────────
# Google Gemini API Key
GOOGLE_API_KEY=你的_GEMINI_API_KEY

# 報告生成 / 規格問答用模型（較強）
CHAT_MODEL=gemini-2.5-flash

# 意圖解析用模型（速度快、成本低）
INTENT_MODEL=gemini-2.5-flash

# LLM 每分鐘呼叫上限（RPM 限流，預設 10）
LLM_RPM_LIMIT=10

# ── Datasheet Product Expert API（型號規格問答，Type B 查詢用）───────────
PRODUCT_API_URL=你的_PRODUCT_EXPERT_API_URL
PRODUCT_API_KEY=你的_PRODUCT_EXPERT_API_KEY
PRODUCT_API_TIMEOUT=120

# 測試開關：設值時 /api/chat 停用原本 3-Stage Pipeline，全部訊息直接走指定的測試路徑
# 可用值："datasheet_api" / "vector_search"，留空則走正常 Pipeline
CHAT_TEST_MODE=
